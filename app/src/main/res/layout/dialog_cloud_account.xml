<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/cloud_login_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cloud_config_hint"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/cloud_config_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/cloud_config_placeholder"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="5"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/cloud_scan_qr_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cloud_scan_qr"
            android:drawableStart="@android:drawable/ic_menu_camera"
            android:drawablePadding="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/cloud_login_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cloud_login" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/cloud_logged_in_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cloud_display_name"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/cloud_display_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/cloud_logout_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cloud_logout" />

        <Button
            android:id="@+id/cloud_qr_web_login_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cloud_qr_web_login"
            android:drawableStart="@android:drawable/ic_menu_camera"
            android:drawablePadding="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
